# Telegram 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (각 사용자가 /start 후 확인)
PARENT_CHAT_ID=123456789
JIHU_CHAT_ID=987654321
YUNHU_CHAT_ID=111222333

# Google Sheets ID (URL에서 추출: https://docs.google.com/spreadsheets/d/{이 부분}/edit)
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Google 서비스 계정 인증 파일 경로
GOOGLE_CREDENTIALS_FILE=credentials.json

# 알림 시간 (KST 기준, 24시간 형식)
TASK_SEND_HOUR=22
TASK_SEND_MINUTE=0
SUMMARY_HOUR=23
SUMMARY_MINUTE=0
